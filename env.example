# ============================================================
# FOAM — Environment Variables Reference
# ============================================================
# DO NOT commit actual values to source control.
# Add these to Replit Secrets and Supabase Edge Function secrets.
#
# Supabase CLI: supabase secrets set KEY=value
# Replit: Secrets tab in the sidebar
# ============================================================

# ── Supabase ─────────────────────────────────────────────────
SUPABASE_URL=https://[your-project-ref].supabase.co
SUPABASE_ANON_KEY=eyJ...              # Safe for client-side (React Native)
SUPABASE_SERVICE_ROLE_KEY=eyJ...      # Server only — Edge Functions ONLY, never client

# ── Stripe ───────────────────────────────────────────────────
STRIPE_PUBLISHABLE_KEY=pk_test_...    # Safe for client-side (React Native)
STRIPE_SECRET_KEY=sk_test_...         # Server only — Edge Functions ONLY
STRIPE_WEBHOOK_SECRET=whsec_CBUaLBR0C7p4C0OY9UAEaa1NoYW6ZFt1
STRIPE_WEBHOOK_SECRET_CONNECT=whsec_AcJyaqbqiFmkPypYQk15PHlvM1XA0yPT

# ── Stripe Product IDs ───────────────────────────────────────
STRIPE_PRODUCT_STARTER=prod_URLXUcfPQqNnG5
STRIPE_PRODUCT_PRO=prod_URLZ7lo16NLbv0
STRIPE_PRODUCT_CREW=prod_URLdJBZUUvWku3
STRIPE_PRODUCT_RAIN_COVERAGE=prod_URLfnBPyvNZB0s

# ── Stripe Price IDs ─────────────────────────────────────────
STRIPE_PRICE_STARTER_MONTHLY=price_1TSUt6AwIiL8fZAde0Fy19mb
STRIPE_PRICE_STARTER_ANNUAL=price_1TSUt6AwIiL8fZAdInDpsipW
STRIPE_PRICE_PRO_MONTHLY=price_1TSUtAAwIiL8fZAdnDKuzvNB
STRIPE_PRICE_PRO_ANNUAL=price_1TSUtAAwIiL8fZAdunlOXxdT
STRIPE_PRICE_CREW_MONTHLY=price_1TSUtCAwIiL8fZAdBxAqGOWK
STRIPE_PRICE_CREW_ANNUAL=price_1TSUtCAwIiL8fZAdMisZ3bCo
STRIPE_PRICE_RAIN_MONTHLY=price_1TSUsxAwIiL8fZAdewS19S0c
STRIPE_PRICE_RAIN_ANNUAL=price_1TSUsxAwIiL8fZAdKCqmEnBl

# ── External APIs ────────────────────────────────────────────
TWILIO_ACCOUNT_SID=AC...
TWILIO_AUTH_TOKEN=...
TWILIO_PHONE_NUMBER=+1...
GOOGLE_MAPS_API_KEY=AIza...
TOMORROW_IO_API_KEY=...

# ── App ──────────────────────────────────────────────────────
APP_BASE_URL=foam://              # Deep link scheme for Stripe Connect return URLs
                                  # Change to https://foam.app in production

# ── Expo ─────────────────────────────────────────────────────
EXPO_PROJECT_ID=...               # From Expo dashboard after creating the project

# ============================================================
# HOW TO SET SUPABASE EDGE FUNCTION SECRETS
# ============================================================
# supabase secrets set STRIPE_SECRET_KEY=sk_test_...
# supabase secrets set STRIPE_WEBHOOK_SECRET=whsec_...
# supabase secrets set SUPABASE_SERVICE_ROLE_KEY=eyJ...
#
# List current secrets: supabase secrets list
# ============================================================
