{
  "expo": {
    "name": "FOAM",
    "slug": "foam-app",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "automatic",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#0F2F3C"
    },
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.foamauto.app",
      "buildNumber": "1",
      "usesAppleSignIn": true,
      "infoPlist": {
        "NSCameraUsageDescription": "FOAM uses your camera to take before and after photos of detailing jobs.",
        "NSPhotoLibraryUsageDescription": "FOAM needs access to your photo library to upload job photos.",
        "NSLocationWhenInUseUsageDescription": "FOAM uses your location to find nearby detailers and navigate to job sites.",
        "NSLocationAlwaysAndWhenInUseUsageDescription": "FOAM uses your location to provide accurate detailer routing.",
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#0F2F3C"
      },
      "package": "com.foamauto.app",
      "versionCode": 1,
      "permissions": [
        "android.permission.ACCESS_COARSE_LOCATION",
        "android.permission.ACCESS_FINE_LOCATION",
        "android.permission.CAMERA",
        "android.permission.READ_EXTERNAL_STORAGE",
        "android.permission.WRITE_EXTERNAL_STORAGE",
        "android.permission.RECEIVE_BOOT_COMPLETED",
        "android.permission.VIBRATE",
        "android.permission.RECORD_AUDIO"
      ]
    },
    "web": {
      "bundler": "metro",
      "output": "single",
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-router",
      "expo-secure-store",
      "expo-apple-authentication",
      [
        "@stripe/stripe-react-native",
        {
          "merchantIdentifier": "merchant.com.foamauto.app",
          "enableGooglePay": true
        }
      ],
      [
        "expo-notifications",
        {
          "icon": "./assets/notification-icon.png",
          "color": "#339DC7",
          "sounds": []
        }
      ],
      [
        "expo-location",
        {
          "locationAlwaysAndWhenInUsePermission": "FOAM uses your location to find nearby detailers and navigate to job sites."
        }
      ],
      [
        "expo-image-picker",
        {
          "photosPermission": "FOAM needs access to your photo library to upload job photos.",
          "cameraPermission": "FOAM uses your camera to take before and after photos."
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    },
    "scheme": "foam",
    "extra": {
      "eas": {
        "projectId": "5f562d98-e671-4444-b2f6-ba7a0c1cb6e8"
      },
      "router": {
        "origin": false
      }
    }
  }
}
